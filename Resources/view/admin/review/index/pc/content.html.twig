{% trans_default_domain('products-review.admin') %}

<main class="main d-print-none ">

    <section class="container px-4 mb-5">

        <div class="mt-3 d-flex justify-content-between">
            {{ include(_self|replace({ "content.html.twig": "_breadcrumb.html.twig" })) }}
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3 gap-3">

            <div class="w-100">
                <h1 class="h4 text-uppercase fw-bolder mb-0">
                    {{ 'page.reviews.index'|trans }}
                </h1>
            </div>

        </div>

        <div class="border  border-light  rounded-4 p-3 p-3">
            {# Фильтр по статусам отзывов #}
            <div class="d-flex gap-3 justify-content-between mb-3 align-items-center">

                {# Форма поиска по разделу #}
                {% include Template('/_includes/'~baks_settings.device~'/search.html.twig') %}

                {{ include(_self|replace({ "content.html.twig": "filter.html.twig" })) }}
            </div>

            <table class="table table-striped table-borderless mt-3"
                   style='--bs-table-striped-bg: rgba(249,249,249,0.7);'
            >
                <thead>

                <tr>
                    <th>#</th>
                    <th></th>
                    <th class='text-center'>Статуc</th>
                    <th class='text-center'>Пользователь</th>
                    <th class='text-nowrap'>Имя в отзыве</th>
                    <th class='w-50 text-center'>Продукт</th>
                    <th class='w-100 text-center'>Сообщение</th>
                    <th class='w-100 text-center'>Оценка</th>
                    <th class='w-100 text-center'>Склад</th>
                    <th class='w-100 text-center'>Тип отзыва</th>
                </tr>

                </thead>

                <tbody>
                {% for item in query.data %}
                    {{ include(_self|replace({ "content.html.twig": "card.html.twig" })) }}
                {% endfor %}
                <tbody>

            </table>

            {% if query.data %}

                <div class="position-absolute mt-2 pt-1 small">
                    <strong class="">Множественный выбор:</strong>
                </div>

                <div class="to-invoice-actions d-flex gap-2 sticky-bottom ps-5 pb-3 pt-2 z-1"
                     style="margin-left: 130px; max-width: 100px;">

                    <button class="btn btn-sm btn-outline-primary text-nowrap mb-2"
                            role="tooltip"
                            data-bs-toggle="tooltip"
                            data-bs-placement="bottom"
                            data-bs-delay='{"show":600,"hide":100}'
                            title="Выбрать все"
                            id="select-all-to-edit">
                        Выбрать все
                    </button>

                    <a class="btn btn-sm btn-danger text-nowrap mb-2 d-none"
                       role="tooltip"
                       data-bs-placement="bottom"
                       data-bs-delay='{"show":600,"hide":100}'
                       title="Удалить выбранные"
                       id="add-all-to-delete"

                       data-bs-toggle="modal"
                       data-bs-target="#modal"

                       data-post-class="add-all-to-edit"

                       data-method="post"
                       data-collection-form="collection"
                       data-formname="{{ add_selected_delete_form_name }}"
                       href="{{ path('products-review:admin.review.delete' ) }}">
                        Удалить выбранные
                    </a>

                    <a class="btn btn-sm btn-success text-nowrap mb-2 d-none"
                       role="tooltip"
                       data-bs-placement="bottom"
                       data-bs-delay='{"show":600,"hide":100}'
                       title="Сделать активными выбранные"
                       id="add-all-to-active"

                       data-bs-toggle="modal"
                       data-bs-target="#modal"

                       data-post-class="add-all-to-edit"

                       data-method="post"
                       data-collection-form="collection"
                       data-formname="{{ add_selected_active_form_name }}"
                       href="{{ path('products-review:admin.review.newedit.status.active' ) }}">
                        Сделать активными выбранные
                    </a>

                </div>
            {% endif %}


            {# Пагинация #}
            {% include Template('_includes/'~baks_settings.device~'/pagination.html.twig') with { 'pagination' : query } %}

        </div>


    </section>

</main>