{% trans_default_domain('products-review.admin') %}


<div class="modal-dialog modal-dialog-centered" style="max-width: 800px;">
    {{ form_start(form) }}
    <div class="modal-content p-3 border-bottom border-5 border-primary">
        <div class="modal-header">
            <h5 class="modal-title">
                {{ 'page.reviews.edit'|trans }}
            </h5>
        </div>

        <div class="modal-body">

            {{ form_widget(form.category) }}
            {{ form_widget(form.product) }}
            {{ form_widget(form.user) }}
            {{ form_widget(form.name) }}
            {{ form_widget(form.status) }}
            {{ form_widget(form.text) }}


            <div class="row row-cols-2">

                {% for criterion in form.criteria %}

                    <div class="d-flex-n justify-content-between align-items-center">

                        {{ form_row(criterion.criteria) }}

                        <div class="rate d-flex justify-content-between align-items-center gap-2">
                            {{ form_label(criterion.rating) }}
                            {{ form_widget(criterion.rating, {'attr': {'class': 'd-flex'}}) }}
                        </div>

                        {{ form_row(criterion.name, { attr: { class: 'd-none' } }) }}
                    </div>


                {% endfor %}
            </div>

        </div>

        <div class="modal-footer">
            <div class="mt-3 gap-3 d-flex">
                {# Отмена #}
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    {{ 'btn.cancel'|trans({}, 'core.btn') }}
                </button>
                {{ form_widget(form.edit_product_review, { label: '
                    <span>'~ 'Сохранить'|trans({}, 'core.btn') ~'</span>
                    <span class="spinner-border spinner-border-sm vertical-middle d-none"></span>
			    '}) }}
                {{ form_end(form) }}
            </div>
        </div>

    </div>

</div>
