{% trans_default_domain('products-review.admin') %}

<div class="modal-dialog modal-dialog-centered" style="max-width: 800px;">
    {{ form_start(form) }}
    <div class="modal-content p-3 border-bottom border-5 border-primary">
        <div class="modal-header">

            <h5 class="modal-title">
                {# Заголовок модального окна #}
                {{ 'form.reviews.header.status'|trans }}

            </h5>

            <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                <span class="svg-icon svg-icon-2x"></span>
            </div>
        </div>

        <div class="modal-body">
            {# Вы уверены, что желаете изменить статус выбранных отзывов? #}
            {{ 'form.reviews.label.status'|trans }}
        </div>

        {% for collection in form.collection %}
            {{ form_widget(collection.id) }}
        {% endfor %}

        <div class="modal-footer">
            <div class="flex-grow-1">
                &nbsp;
            </div>
            {# Отмена #}
            <div class="d-flex gap-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    {{ 'btn.cancel'|trans({}, 'core.btn') }}
                </button>


                {# Сохранить #}
                {{ form_widget(form.change_status_selected_reviews, { label: '
                    <span>'~ 'btn.save'|trans({}, 'core.btn') ~'</span>
                    <span class="spinner-border spinner-border-sm vertical-middle d-none"></span>
			    '}) }}
            </div>
        </div>
    </div>
    {{ form_end(form) }}
</div>
