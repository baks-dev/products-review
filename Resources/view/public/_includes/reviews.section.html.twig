<style>
    /* Стиль для обрезанного текста */
    .review-content .truncated-text {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Когда текст раскрыт — убрать ограничение */
    .review-content .expanded-text {
        display: block;
        overflow: visible;
    }

    .rotated svg {
        transform: rotate(180deg);
        transition: transform 0.3s ease; /* Для плавного поворота */
    }
</style>


